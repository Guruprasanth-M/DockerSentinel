# .env.example
# Copy to .env: cp .env.example .env

# ─── Versions ──────────────────────────────
HOSTSPECTRA_VERSION=0.1.0

# ─── Redis ─────────────────────────────────
# Internal Docker network URL used by all services
REDIS_URL=redis://redis:6379

# ─── Config paths ──────────────────────────
# Path to config file inside all service containers
HOSTSPECTRA_CONFIG=/config/hostspectra.yml

# ─── Data directories ──────────────────────
# These must exist on the server before running docker compose up
# Create them with: mkdir -p data/redis data/models data/audit data/collector-state
# Redis specifically needs write permission: chmod 777 data/redis
DATA_DIR=./data

# ─── Network ───────────────────────────────
# Port the dashboard binds to on the server
# Access dashboard at: http://YOUR_SERVER_IP:${DASHBOARD_PORT}
DASHBOARD_PORT=8080

# ─── Compose project name ──────────────────
# Prefixes all container names: hostspectra-redis, hostspectra-api, etc.
COMPOSE_PROJECT_NAME=hostspectra
